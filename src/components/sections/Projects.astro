---
import Section from "@/components/Section.astro";
import { projects } from "@cv";
---

<Section title="Projects">
    <div class="projects-grid">
        {
            projects.map(({ name, description, url }) => {
                return (
                    <a href={url} class="project-card" target="_blank" rel="noopener noreferrer">
                        <article>
                            <header>
                                <h3>{name}</h3>
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="external-icon">
                                    <path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                </svg>
                            </header>
                            <p>{description}</p>
                        </article>
                    </a>
                );
            })
        }
    </div>
</Section>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
    }

    .project-card {
        text-decoration: none;
        display: block;
        padding: 1.25rem;
        border-radius: 12px;
        background: #181825;
        border: 1px solid #313244;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
    }

    .project-card:hover {
        border-color: #cba6f7;
        background: #1e1e2e;
        transform: translateY(-4px);
        box-shadow: 0 10px 20px -10px rgba(0, 0, 0, 0.5);
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }

    h3 {
        color: #89b4fa;
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .external-icon {
        color: #6c7086;
        transition: color 0.3s ease;
    }

    .project-card:hover .external-icon {
        color: #f5e0dc;
    }

    p {
        color: #a6adc8;
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0;
    }

    @media (max-width: 640px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>