---
import Section from "@/components/Section.astro";

// 1. Get all your posts
const allPosts = Object.values(
  import.meta.glob("../../pages/posts/*.md", { eager: true })
);

// 2. Helper to format dates inside the loop
const formatDate = (date: string) => 
    new Date(date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
---

<Section title="Posts">
    <div class="posts-container">
        {allPosts.map((post: any) => (
            <a href={post.url} class="post-card">
                <article>
                    <time datetime={post.frontmatter.pubDate}>
                        {formatDate(post.frontmatter.pubDate)}
                    </time>
                    <h2>{post.frontmatter.title}</h2>
                    <p>{post.frontmatter.description}</p>
                    <div class="read-more">Read article →</div>
                </article>
            </a>
        ))}
    </div>
</Section>

<style>
    /* Keep your existing styles exactly as they are */
    .posts-container {
        display: flex;
        flex-direction: column;
        gap: 1rem; /* Adds spacing between cards */
    }

    .post-card {
        text-decoration: none;
        display: block;
        padding: 1.5rem;
        border-radius: 12px;
        background: #181825; /* Catppuccin Mantle/Crust feel */
        border: 1px solid #313244;
        transition: all 0.3s ease;
    }

    .post-card:hover {
        border-color: #89b4fa; /* Blue accent */
        transform: translateX(4px);
        background: #1e1e2e;
    }

    time {
        font-size: 0.75rem;
        color: #b4befe; /* Lavender */
        text-transform: uppercase;
    }

    h2 {
        color: #cdd6f4; /* Text */
        font-size: 1.25rem;
        margin: 0.5rem 0;
        font-weight: 700;
    }

    p {
        color: #a6adc8; /* Subtext */
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 1rem;
    }

    .read-more {
        font-size: 0.8rem;
        font-weight: 600;
        color: #fab387; /* Peach */
    }
</style>