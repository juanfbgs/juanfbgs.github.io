---
import Section from "@/components/Section.astro";
import { basics } from "@cv";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/Github.astro";
import type { SocialIcon } from "@/types";

const SOCIAL_ICONS: SocialIcon = {
    GitHub,
    LinkedIn,
};

const { name, label, country, profiles } = basics;
---

<Section>
    <div class="container">
        <div class="info">
            <h1>{name}</h1>
            <h2>{label}</h2>
            <h3>{country}</h3>
            <footer>
                {
                    profiles.map(({ network, url, username }) => {
                        const Icon = SOCIAL_ICONS[network];

                        return (
                            <a
                                href={url}
                                title={`Visit profile ${username} on ${network}`}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <Icon />
                            </a>
                        );
                    })
                }
            </footer>
        </div>
    </div>

    <style>
        .container {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
        }

        .info {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            padding-right: 2px;
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
        }

        h2 {
            color: #bac2de;
            font-weight: 500;
            font-size: 1.5rem;
        }

        h3 {
            color: #a6adc8;
            font-weight: 300;
            font-size: 1rem;
        }

        footer {
            color: #a6adc8;
            font-size: 0.65rem;
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        footer a {
            color: #bac2de;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #313244;
            padding: 4px;
            height: 32px;
            width: 32px;
            border-radius: 6px;
            transition: all 0.3s ease;
            background: #181825;
        }

        footer a:hover {
            background: #45475a;
            border: 1px solid #6c7086;
            color: #89dceb;
            transform: translateY(-2px);
        }
    </style>
</Section>
